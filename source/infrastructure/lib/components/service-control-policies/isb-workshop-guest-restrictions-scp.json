{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "WorkshopInstanceSizeRestrictions",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances"
      ],
      "Resource": ["arn:aws:ec2:*:*:instance/*"],
      "Condition": {
        "ForAnyValue:StringNotLike": {
          "ec2:InstanceType": [
            "t2.micro",
            "t2.small",
            "t2.medium",
            "t3.micro",
            "t3.small",
            "t3.medium",
            "t3a.micro",
            "t3a.small",
            "t3a.medium"
          ]
        },
        "ArnNotLike": {
          "aws:PrincipalARN": [
            "arn:aws:iam::*:role/InnovationSandbox-${namespace}*",
            "arn:aws:iam::*:role/aws-reserved/sso.amazonaws.com/*AWSReservedSSO_${namespace}_IsbAdmins*",
            "arn:aws:iam::*:role/stacksets-exec-*",
            "arn:aws:iam::*:role/AWSControlTowerExecution"
          ]
        }
      }
    },
    {
      "Sid": "WorkshopDangerousActionsRestrictions",
      "Effect": "Deny",
      "Action": [
        "organizations:LeaveOrganization",
        "organizations:CloseAccount",
        "organizations:DeleteOrganization",
        "iam:CreateUser",
        "iam:CreateAccessKey",
        "iam:CreateLoginProfile",
        "iam:DeactivateMFADevice",
        "iam:DeleteAccountPasswordPolicy",
        "ec2:CreateVpcPeeringConnection",
        "ec2:AcceptVpcPeeringConnection",
        "ec2:AttachInternetGateway",
        "ram:CreateResourceShare",
        "ram:EnableSharingWithAwsOrganization",
        "route53domains:RegisterDomain",
        "route53domains:TransferDomain",
        "lightsail:*",
        "gamelift:*",
        "appstream:*",
        "mechanicalturk:*",
        "ground-station:*"
      ],
      "Resource": ["*"],
      "Condition": {
        "ArnNotLike": {
          "aws:PrincipalARN": [
            "arn:aws:iam::*:role/InnovationSandbox-${namespace}*",
            "arn:aws:iam::*:role/aws-reserved/sso.amazonaws.com/*AWSReservedSSO_${namespace}_IsbAdmins*",
            "arn:aws:iam::*:role/stacksets-exec-*",
            "arn:aws:iam::*:role/AWSControlTowerExecution"
          ]
        }
      }
    },
    {
      "Sid": "WorkshopCostProtection",
      "Effect": "Deny",
      "Action": [
        "ec2:Purchase*",
        "rds:Purchase*",
        "redshift:Purchase*",
        "elasticache:Purchase*",
        "es:Purchase*",
        "dynamodb:Purchase*",
        "savingsplans:CreateSavingsPlan",
        "aws-portal:ModifyBilling",
        "aws-portal:ModifyPaymentMethods",
        "cur:PutReportDefinition"
      ],
      "Resource": ["*"],
      "Condition": {
        "ArnNotLike": {
          "aws:PrincipalARN": [
            "arn:aws:iam::*:role/InnovationSandbox-${namespace}*",
            "arn:aws:iam::*:role/aws-reserved/sso.amazonaws.com/*AWSReservedSSO_${namespace}_IsbAdmins*",
            "arn:aws:iam::*:role/stacksets-exec-*",
            "arn:aws:iam::*:role/AWSControlTowerExecution"
          ]
        }
      }
    }
  ]
}
